[init]
  defaultBranch = main
[user]
  name = Adrian Rego
  email = arego320@gmail.com
  signingkey = 63545724A9F7EF0E
[push]
  default = tracking
[core]
  excludesfile = ~/.gitignore_global
  autocrlf = false
[commit]
  gpgsign = true
[pull]
  rebase = false
[includeIf "gitdir:~/Code/work/"]
  path = ~/.gitconfig.work
[credential "https://github.com"]
	helper = 
	helper = !/home/linuxbrew/.linuxbrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/home/linuxbrew/.linuxbrew/bin/gh auth git-credential
